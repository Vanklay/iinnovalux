---
import { company } from '../../data/company';
---

<section class="py-12 md:py-16">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="rounded-2xl overflow-hidden border border-white/5 bg-dark-tertiary">
      <div class="aspect-[16/9] md:aspect-[21/9] relative">
        <iframe
          src="https://maps.google.com/maps?q=76+Haaptstrooss+L-6661+Born+Luxembourg&output=embed&hl=fr"
          class="absolute inset-0 w-full h-full border-0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Localisation de ${company.name}`}
        ></iframe>

        <!-- Overlay for better visual integration -->
        <div class="absolute inset-0 pointer-events-none border border-white/5 rounded-2xl"></div>
      </div>
    </div>
  </div>
</section>
