---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroPage from '../components/sections/HeroPage.astro';
import ContactInfo from '../components/sections/ContactInfo.astro';
import ContactForm from '../components/sections/ContactForm.astro';
import Map from '../components/sections/Map.astro';
---

<BaseLayout
  title="Devis Gratuit et Contact Bricoleur Luxembourg"
  description="Contactez IINNOVALUX pour un devis gratuit au Luxembourg. Appelez +352 621 479 364 ou écrivez-nous. Réponse rapide sous 24h. Born, Luxembourg."
  breadcrumb={[{ label: 'Accueil', href: '/' }, { label: 'Contact' }]}
>
  <!-- ContactPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": "https://iinnovalux.lu/contact#page",
    "url": "https://iinnovalux.lu/contact",
    "name": "Contactez IINNOVALUX - Devis Gratuit",
    "description": "Contactez IINNOVALUX pour un devis gratuit au Luxembourg. Réponse sous 24h.",
    "inLanguage": "fr-LU",
    "mainEntity": {
      "@type": "LocalBusiness",
      "@id": "https://iinnovalux.lu/#business"
    }
  })} />
  <HeroPage
    title="Contactez-nous"
    subtitle="Nous sommes à votre disposition pour répondre à toutes vos questions"
    breadcrumb={[
      { label: 'Accueil', href: '/' },
      { label: 'Contact' }
    ]}
  />

  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <div data-reveal>
          <ContactInfo />
        </div>
        <div data-reveal data-reveal-delay="1">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <Map />
</BaseLayout>
